<?xml version="1.0" encoding="utf-8"?>
<!--
    bg_word_lunar.xml - Fundo da Palavra Oculta no Jogo
    Este drawable define o estilo do fundo onde a palavra oculta
    é exibida na tela do jogo (GameActivity).
-->

<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- COR DE FUNDO -->
    <solid android:color="#1A1E2A" /> <!-- Azul escuro (mesmo do card) -->

    <!-- CANTOS ARREDONDADOS -->
    <corners android:radius="24dp" />

    <!-- BORDA -->
    <stroke android:width="1dp" android:color="#33FFFFFF" /> <!-- Borda fina / Branco com 20% de opacidade -->

</shape>