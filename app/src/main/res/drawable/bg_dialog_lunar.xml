<?xml version="1.0" encoding="utf-8"?>
<!--
    bg_dialog_lunar.xml - Fundo dos Diálogos
    Este drawable define o estilo dos diálogos personalizados
    (vitória, derrota e tempo esgotado).
-->

<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- COR DE FUNDO-->
    <solid android:color="#E61A1E2A" /> <!-- Azul escuro com 90% de opacidade -->

    <!-- CANTOS ARREDONDADOS -->
    <corners android:radius="48dp" /> <!-- Cantos bem arredondados -->

    <!-- BORDA -->
    <stroke android:width="1.5dp" android:color="#50FFFFFF" /> <!-- Borda fina / Branco com 31% de opacidade -->

</shape>