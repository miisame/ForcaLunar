<?xml version="1.0" encoding="utf-8"?>
<!--
    bg_word_dialog.xml - Fundo da Palavra Revelada nos Diálogos
    Este drawable define o estilo do "chip" ou "badge" que exibe
    a palavra secreta nos diálogos de vitória, derrota e tempo esgotado.
-->

<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- COR DE FUNDO-->
    <solid android:color="#2A2F42" /> <!-- Azul escuro -->

    <!-- CANTOS ARREDONDADOS -->
    <corners android:radius="40dp" />

    <!-- BORDA -->
    <stroke android:width="1dp" android:color="#30FFFFFF" /> <!-- Borda fina / Branco com 19% de opacidade -->

</shape>