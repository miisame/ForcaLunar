<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/bg_gradient_lunar"
    android:gravity="center">

    <!-- Card principal -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_card_lunar"
        android:padding="32dp"
        android:layout_margin="16dp">

        <!-- Título -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/ic_lua"
            android:textSize="48sp"
            android:layout_gravity="center" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/titulo_app"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/moon_text_light"
            android:layout_gravity="center"
            android:layout_marginTop="8dp" />

        <!-- Seleção de avatar -->
        <ImageView
            android:id="@+id/imgAvatarSelecionado"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:layout_gravity="center"
            android:layout_marginTop="16dp"
            android:src="@android:drawable/ic_menu_camera"
            android:background="@drawable/edittext_lunar"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/desc_selecionar_avatar"
            android:scaleType="centerCrop"/>

        <!-- Campo de Nick -->
        <EditText
            android:id="@+id/editNick"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:autofillHints=""
            android:hint="@string/hint_nick"
            android:inputType="text"
            android:textColor="@color/moon_text_light"
            android:textColorHint="@color/moon_gold_dim"
            android:background="@drawable/edittext_lunar"
            android:padding="16dp"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="24dp" />

        <!-- Botão Iniciar -->
        <Button
            android:id="@+id/btnIniciar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/botao_iniciar"
            android:background="@drawable/btn_primary_lunar"
            android:textColor="@color/moon_dark_bg"
            android:textSize="16sp"
            android:padding="14dp"
            android:layout_marginBottom="16dp" />

        <!-- Botão Cadastrar -->
        <Button
            android:id="@+id/btnCadastrar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/tela_cadastrar"
            android:background="@drawable/btn_secondary_lunar"
            android:textColor="@color/moon_text_light"
            android:textSize="16sp"
            android:padding="14dp" />

    </LinearLayout>
</LinearLayout>