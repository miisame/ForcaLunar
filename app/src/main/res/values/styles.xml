<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Tema principal da aplicação - Cavaleiro da Lua -->
    <style name="Theme.ForcaLunar" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/moon_silver_bright</item>
        <item name="colorPrimaryVariant">@color/moon_silver_dim</item>
        <item name="colorOnPrimary">@color/moon_dark_bg</item>
        <item name="colorSecondary">@color/moon_gold</item>
        <item name="colorSecondaryVariant">@color/moon_gold_dim</item>
        <item name="colorOnSecondary">@color/moon_dark_bg</item>
        <item name="android:statusBarColor">@color/moon_dark_bg</item>
        <item name="android:navigationBarColor">@color/moon_dark_bg</item>
    </style>

    <!-- Estilo base para botões lunares -->
    <style name="LunarButton" parent="Widget.MaterialComponents.Button.UnelevatedButton">
        <item name="android:textColor">@color/moon_dark_bg</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:paddingLeft">24dp</item>
        <item name="android:paddingRight">24dp</item>
        <item name="android:letterSpacing">0.05</item>
    </style>

    <!-- Estilo para botão secundário (texto branco) -->
    <style name="LunarButtonSecondary" parent="LunarButton">
        <item name="android:textColor">@color/moon_text_light</item>
    </style>

    <!-- Estilo para textos de título -->
    <style name="LunarTitle">
        <item name="android:textColor">@color/moon_text_light</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.05</item>
    </style>

    <!-- Estilo para textos secundários -->
    <style name="LunarSubtitle">
        <item name="android:textColor">@color/moon_gold_dim</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <!-- Estilo para textos informativos -->
    <style name="LunarInfo">
        <item name="android:textColor">@color/moon_gold_dim</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <!-- Estilo para os botões do teclado -->
    <style name="LunarKeyboardButton">
        <item name="android:textColor">@color/moon_text_light</item>
        <item name="android:textSize">14sp</item>
        <item name="android:background">@drawable/btn_keyboard_lunar</item>
        <item name="android:padding">8dp</item>
        <item name="android:gravity">center</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Estilo para diálogos personalizados - Cavaleiro da Lua -->
    <style name="CustomDialogTheme" parent="Theme.MaterialComponents.Dialog.Alert">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.7</item>
    </style>

    <!-- Botão secundário (SAIR) -->
    <style name="DialogButtonSecondary">
        <item name="android:background">@drawable/btn_dialog_secondary</item>
        <item name="android:textColor">@color/moon_gold_dim</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:paddingTop">10dp</item>
        <item name="android:paddingBottom">10dp</item>
        <item name="android:paddingLeft">20dp</item>
        <item name="android:paddingRight">20dp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.03</item>
    </style>

    <!-- Botão primário (NOVA PARTIDA) -->
    <style name="DialogButtonPrimary">
        <item name="android:background">@drawable/btn_dialog_primary</item>
        <item name="android:textColor">@color/moon_dark_bg</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:paddingTop">10dp</item>
        <item name="android:paddingBottom">10dp</item>
        <item name="android:paddingLeft">20dp</item>
        <item name="android:paddingRight">20dp</item>
        <item name="android:fontFamily">sans-serif-bold</item>
        <item name="android:letterSpacing">0.03</item>
    </style>
</resources>